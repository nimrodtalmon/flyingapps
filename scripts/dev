#!/usr/bin/env bash
# scripts/dev — serve the site locally.
# Usage:  ./scripts/dev [port]   (default 8000)
set -euo pipefail

cd "$(dirname "$0")/.."

PORT="${1:-8000}"
URL="http://localhost:${PORT}/"

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required but not installed." >&2
  exit 1
fi

if ! [ -f docs/index.html ]; then
  echo "docs/index.html not found — run this from the repo root, or after a fresh clone." >&2
  exit 1
fi

echo "Serving docs/ at ${URL}"
echo "Press Ctrl+C to stop."

# Best-effort: open the browser if we can.
case "$(uname -s)" in
  Darwin) (sleep 1 && open    "${URL}") &>/dev/null & ;;
  Linux)  (sleep 1 && xdg-open "${URL}") &>/dev/null & ;;
esac

exec python3 -m http.server --directory docs "${PORT}"
